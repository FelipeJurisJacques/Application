@implements IObserver
@using System.Numerics;
@using Application.Source.Helpers
@using Application.Source.Utils.Observer
@inject Application.Source.Core.Context _context

<svg viewBox="0 0 @width 100" xmlns="http://www.w3.org/2000/svg">
    <clipPath id="clip">
        <polygon points="
        0,0
        0,100
        @width,100
        @width,0
        1,0
    " />
    </clipPath>
    <!-- <line stroke="#1a1a1a" stroke-width="1" x1="0" x2="@width" y1="0" y2="1" clip-path="url(#clip)"></line> -->
    <polygon fill="#00f2ff" points="@polygonPoints" clip-path="url(#clip)" />
</svg>

@code {
    private int width = 0;
    private string polygonPoints = "";

    protected override void OnInitialized()
    {
        _context.GetDisplay().OnResize().Subscribe(this);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _update();
        }
    }

    public void Update()
    {
        _update();
    }

    private async Task _update()
    {
        width = await _context.GetDisplay().GetWidth();
        List<Vector2> points = [];
        int med = width / 2;
        points.Add(new Vector2(0,0));
        points.Add(new Vector2(0,20));
        points.Add(new Vector2(med - 150,20));
        points.Add(new Vector2(med - 140,5));
        points.Add(new Vector2(med - 40,5));
        points.Add(new Vector2(med - 30,20));
        points.Add(new Vector2(med + 30,20));
        points.Add(new Vector2(med + 40,5));
        points.Add(new Vector2(med + 140,5));
        points.Add(new Vector2(med + 150,20));
        points.Add(new Vector2(@width,20));
        points.Add(new Vector2(@width,0));
        points.Add(new Vector2(0,0));
        polygonPoints = SvgHelper.GeneratePointsAttribute(points);
        StateHasChanged();
    }
}
